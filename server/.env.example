DATABASE_URL=postgresql://postgres:postgres@localhost:5432/studyquiz
REDIS_URL=redis://localhost:6379
PORT=4000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# LLM Providers — set API keys for providers you want to enable
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=AIza-xxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.0-flash
GROK_API_KEY=gsk_xxxxxxxxxxxxxxxx
GROK_MODEL=llama-3.3-70b-versatile

# Default provider (openai | gemini | grok) — falls back to first available
LLM_DEFAULT_PROVIDER=grok
